{
  "name": "transaction-search-tool",
  "version": "1.0.0",
  "description": "Administration tool for Front End Scanned (FES) documents to enable users to monitor, audit and investigate the routing, status and journey of Front End Scanned document submissions",
  "main": "dist/app/app.js",
  "scripts": {
    "build": "tsc && cp -r src/views dist/app/ && cp -r src/static dist/app/",
    "lint": "eslint 'src/**/*'",
    "lint:fix": "eslint 'src/**/*' --fix",
    "test": "nyc mocha -r ts-mocha src/test/**/*.test.ts && nyc report --reporter=lcov",
    "sonarqube-base-branch": "sonar-scanner",
    "sonarqube-pull-request": "sonar-scanner -D sonar.pullrequest.base=main",
    "analyse-code": "branch=$(git rev-parse --symbolic-full-name --abbrev-ref HEAD); if [[ $branch == \"HEAD\" ]]; then echo $branch && npm run sonarqube-base-branch; else echo $branch && npm run sonarqube-pull-request; fi;",
    "chs-dev": "nodemon --legacy-watch"
  },
  "author": "companieshouse",
  "license": "MIT",
  "dependencies": {
    "@companieshouse/node-session-handler": "^5.2.10",
    "@companieshouse/structured-logging-node": "^2.0.9",
    "@companieshouse/web-security-node": "^4.4.15",
    "@types/express": "~4.17.6",
    "@types/node": "^14.14.6",
    "body-parser": "^1.20.3",
    "cookie-parser": "~1.4.4",
    "dirty-chai": "^2.0.1",
    "dotenv": "^8.2.0",
    "express": "^4.21.0",
    "express-session": "^1.17.1",
    "govuk-frontend": "^3.9.1",
    "helmet": "^4.4.1",
    "jiti": "^2.6.1",
    "lint": "^1.1.2",
    "mongodb": "^3.6.5",
    "nunjucks": "^3.2.2",
    "nyc": "^15.1.0",
    "oracledb": "^6.0.0",
    "ts-node": "^9.0.0",
    "typescript": "^4.0.3",
    "winston": "~3.3.3"
  },
  "nodemonConfig": {
    "watch": [
      "./src"
    ],
    "ext": "ts",
    "exec": "ts-node ./src/app.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^4.2.14",
    "@types/mocha": "^8.0.3",
    "@types/sinon": "^9.0.8",
    "chai": "^4.2.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.1",
    "proxyquire": "^2.1.3",
    "sinon": "^9.2.1",
    "sinon-chai": "^3.5.0",
    "sonarqube-scanner": "^3.5.0",
    "ts-mocha": "^10.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  }
}
